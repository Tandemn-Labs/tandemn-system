# Tandemn Orca — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── OpenRouter (placement engine) ──
TD_OPENROUTER_KEY=

# ── Redis (chunk queue) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Control Plane ──
# The IP/hostname workers use to reach this server's Redis.
# On AWS: the private IP of the control plane EC2 instance.
CONTROL_PLANE_IP=localhost
