# ─── Required ────────────────────────────────────────────────────────────────

# AWS credentials — used by SkyPilot (cluster launch) and boto3 (S3)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for job inputs and outputs
S3_UPLOAD_BUCKET=my-orca-bucket

# HuggingFace token — required for gated models (Llama, Gemma, Mistral, etc.)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Anthropic API key — required for the LLM placement advisor
# Not needed if TD_PLACEMENT_SOLVER=roofline (the default)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Public URL where EC2 replicas can reach this server.
TD_SERVER_URL=https://your-server-url.example.com

# Secret for securing internal replica callbacks (metrics, chunks, lifecycle).
# Leave empty to disable auth (local dev only).
ORCA_API_KEY=
