def c(text, color):
    return f"{color}{text}{RESET}"

def bar(pct, width=40):
    filled = int(width * pct)
    empty = width - filled
    if pct >= 1.0:
        color = GREEN
    elif pct >= 0.5:
        color = CYAN
    else:
        color = BLUE
    return f"{color}{'█' * filled}{'░' * empty}{RESET} {pct*100:5.1f}%"

def visible_len(text):
    return len(re.sub(r'\033\[[0-9;]*m', '', text))

def spinner(message, stop_event):
    """Orca swimming across the terminal while waiting."""
    orca_frames = [
        f"{CYAN}~{BOLD}><(((o>{RESET}",   # swimming right
        f"{CYAN}~~{BOLD}><(((o>{RESET}",
        f"{CYAN}~~~{BOLD}><(((o>{RESET}",
        f"{CYAN}~{BOLD}><(((o>{RESET}~",
    ]
    fish_len = 8  # visible length of ><(((o>
    width = 30
    pos = 0
    frame = 0
    try:
        while not stop_event.is_set():
            orca = orca_frames[frame % len(orca_frames)]
            pad_left = pos % width
            pad_right = max(0, width - pad_left - fish_len)
            water_left = f"{DIM}{'~' * pad_left}{RESET}"
            water_right = f"{DIM}{'~' * pad_right}{RESET}"
            line = f"\r  {water_left}{orca}{water_right} {DIM}{message}{RESET}"
            # Overwrite any trailing chars from previous longer lines
            sys.stdout.write(line + "    ")
            sys.stdout.flush()
            pos += 1
            frame += 1
            stop_event.wait(0.15)
    except Exception:
        pass
    # Clear the spinner line
    sys.stdout.write("\r" + " " * 80 + "\r")
    sys.stdout.flush()


def api_with_spinner(method, path, message="Working...", **kwargs):
    """Make an API call with an orca spinner while waiting."""
    import threading as _thr
    stop = _thr.Event()
    spin_thread = _thr.Thread(target=spinner, args=(message, stop), daemon=True)
    spin_thread.start()
    try:
        result = api(method, path, **kwargs)
    finally:
        stop.set()
        spin_thread.join(timeout=2)
    return result


def box(lines, title="", width=72):
    top = f"╭─{'─ ' + c(title, BOLD+CYAN) + ' ─' if title else '─'}" + "─" * (width - len(title) - 6 if title else width - 2) + "╮"
    bottom = f"╰{'─' * (width)}╯"
    result = [top]
    for line in lines:
        padding = max(0, width - visible_len(line))
        result.append(f"│ {line}{' ' * padding}│")
    result.append(bottom)
    return "\n".join(result)


