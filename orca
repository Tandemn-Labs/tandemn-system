# ─── Input file parsing (standalone, no server deps) ────────────────────────
def parse_input_file(input_file: str) -> dict:
    """Parse a JSONL batch file and return stats."""
    prompts = []
    max_tokens_list = []
    with open(input_file) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            entry = json.loads(line)
            body = entry.get("body", {})
            messages = body.get("messages", [])
            text = " ".join(m.get("content", "") for m in messages)
            prompts.append(text)
            max_tokens_list.append(body.get("max_tokens", 256))

    char_estimates = [max(1, len(p) // 4) for p in prompts]
    return {
        "num_lines": len(prompts),
        "avg_input_tokens": sum(char_estimates) // max(1, len(prompts)),
        "max_input_tokens": max(char_estimates) if char_estimates else 0,
        "avg_max_output_tokens": sum(max_tokens_list) // max(1, len(max_tokens_list)),
        "max_output_tokens": max(max_tokens_list) if max_tokens_list else 256,
    }


# ─── Server communication helpers ───────────────────────────────────────────
def api(method, path, **kwargs):
    """Make an HTTP request to the Orca server."""
    url = f"{ORCA_SERVER}{path}"
    try:
        resp = getattr(requests, method)(url, timeout=kwargs.pop("timeout", 600), **kwargs)
        return resp
    except requests.ConnectionError:
        print(f"\n  {RED}Error:{RESET} Cannot reach Orca server at {ORCA_SERVER}")
        print(f"  {DIM}Set ORCA_SERVER env var or start the server.{RESET}\n")
        sys.exit(1)
    except requests.Timeout:
        print(f"\n  {RED}Error:{RESET} Request timed out to {url}")
        sys.exit(1)


def upload_to_server(local_path: str, user: str = "orca-cli") -> str:
    """Upload a local file to S3 via the server's storage endpoint. Returns S3 URI.
    Server decides the S3 bucket/path — CLI just sends the file."""
    basename = os.path.basename(local_path)
    with open(local_path, "rb") as f:
        resp = api("post", "/storage/upload",
                    files={"file": (basename, f)},
                    data={"user": user})
    if resp.status_code != 200:
        print(f"\n  {RED}Upload failed:{RESET} {resp.text}")
        sys.exit(1)
    return resp.json()["storage_uri"]


def split_and_upload_chunks(input_file: str, chunk_size: int) -> list:
    """Split a local JSONL file into chunks, upload each to S3, return chunk metadata."""
    import tempfile as _tf
    chunks = []
    current_lines = []
    chunk_idx = 0

    def _flush(lines, idx):
        cid = f"c{idx:04d}"
        tmp = _tf.NamedTemporaryFile(mode='w', suffix='.jsonl', delete=False)
        tmp.writelines(lines)
        tmp.close()
        s3_uri = upload_to_server(tmp.name)
        os.unlink(tmp.name)
        return {"chunk_id": cid, "s3_input_path": s3_uri, "num_lines": len(lines)}

    with open(input_file) as f:
        for line in f:
            if not line.strip():
                continue
            current_lines.append(line)
            if len(current_lines) >= chunk_size:
                chunks.append(_flush(current_lines, chunk_idx))
                current_lines = []
                chunk_idx += 1
    if current_lines:
        chunks.append(_flush(current_lines, chunk_idx))
    return chunks


