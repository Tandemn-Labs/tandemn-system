def _slo_line(cfg: dict, slo_hours: float) -> str | None:
    """Format SLO ETA line for display boxes. Returns None if no ETA available."""
    eta = cfg.get("estimated_runtime_hours")
    if eta is None:
        return None
    slo_ok = cfg.get("meets_slo", True)
    eta_color = GREEN if slo_ok else RED
    slo_label = "" if slo_ok else f"  {c('MISSES SLO', RED+BOLD)}"
    return f"{DIM}Est. time:{RESET}   {c(f'{eta:.2f}h', eta_color)} / {slo_hours:.1f}h SLO{slo_label}"


def cmd_deploy(args):
    """Deploy a model for batch inference."""
    print(LOGO)
    header("DEPLOY")

    model_name = args.model_name
    input_file = args.input_file
    is_s3 = input_file.startswith("s3://")

    if not is_s3 and not os.path.exists(input_file):
        print(f"\n  {RED}Error:{RESET} Input file not found: {input_file}")
        sys.exit(1)

    # ── Phase 0: Validate --s3-models path if provided ───────────────────
    s3_model_path = getattr(args, 's3_models', None)
    if s3_model_path:
        step(f"Validating S3 model path: {c(s3_model_path, DIM)}")
        import subprocess as _sp
        _check = _sp.run(["aws", "s3", "ls", s3_model_path.rstrip("/") + "/"],
                         capture_output=True, text=True, timeout=15)
        if _check.returncode != 0 or not _check.stdout.strip():
            print(f"\n  {RED}Error:{RESET} Model not found at {s3_model_path}")
            print(f"  {DIM}Check the path and try again.{RESET}\n")
            sys.exit(1)
        step(f"Model found at S3 {c('OK', GREEN)}")

    # ── Phase 1: Parse input ─────────────────────────────────────────────
    if is_s3:
        step("Using S3 input (stats parsed by server)...")
    else:
        step("Parsing input file...")
        stats = parse_input_file(input_file)

        # Output tokens: prefer JSONL per-request max_tokens over CLI default
        if stats.get("has_explicit_max_tokens"):
            effective_avg_output = stats["avg_max_output_tokens"]
            effective_max_output = stats["max_output_tokens"]
            step(f"Output tokens from JSONL: avg={effective_avg_output}, max={effective_max_output}")
        else:
            effective_avg_output = args.max_output_tokens
            effective_max_output = args.max_output_tokens
            step(f"Output tokens from CLI default: {effective_avg_output} (JSONL has no max_tokens)")

        print()
        lines = [
            f"{DIM}File:{RESET}       {c(input_file, WHITE+BOLD)}",
            f"{DIM}Model:{RESET}      {c(model_name, WHITE+BOLD)}",
            f"{DIM}Prompts:{RESET}    {c(str(stats['num_lines']), GREEN+BOLD)}",
            f"{DIM}Avg input:{RESET}  {stats['avg_input_tokens']} tokens",
            f"{DIM}Max input:{RESET}  {stats['max_input_tokens']} tokens",
            f"{DIM}Avg output:{RESET} {effective_avg_output} tokens",
            f"{DIM}Max output:{RESET} {effective_max_output} tokens",
            f"{DIM}SLO:{RESET}        {args.slo} hours",
        ]
        print(box(lines, title="WORKLOAD"))

    # ── Phase 2: Determine replica count + chunk ────────────────────────
    # All jobs go through the chunked Redis pipeline (even with 1 replica).
    # This ensures a single tested code path and enables swap/scale later.
    print()
    chunk_size = getattr(args, 'chunk_size', None) or 1000
    effective_replicas = getattr(args, 'replicas', None) or 1  # default 1 replica

    # Output tokens: use JSONL-derived values if available, else CLI default
    if not is_s3:
        avg_out = effective_avg_output
        max_out = effective_max_output
    else:
        avg_out = args.max_output_tokens
        max_out = args.max_output_tokens

    # Upload input file to S3 upfront (needed for both chunked and single-cluster paths)
    if is_s3:
        s3_input_file = input_file
    else:
        step("Uploading input file to storage...")
        s3_input_file = upload_to_server(input_file)
        step(f"Uploaded to {c(s3_input_file, DIM)}")

    # Build common payload fields
    payload = {
        "placement_solver": "user_specified" if args.gpu else "roofline",
        "user_id": "orca-cli",
        "input_file": s3_input_file,
        "output_file": args.output or "output.jsonl",
        "avg_output_tokens": avg_out,
        "max_output_tokens": max_out,
        "description": f"Orca CLI deploy: {model_name}",
        "task_type": "batch",
        "task_priority": "normal",
        "model_name": model_name,
        "engine": "vllm",
        "slo_mode": "batch",
        "slo_deadline_hours": args.slo,
        "placement": "aws",
        "s3_model_path": getattr(args, 's3_models', None),
        "persist": args.persist,
        "prefer_spot": not args.on_demand,
        "hf_token": os.environ.get("HF_TOKEN", ""),
        "log_level": args.log_level,
    }

    if args.gpu:
        payload["gpu_type"] = args.gpu
        if args.tp:
            payload["tp_size"] = args.tp
        if args.pp:
            payload["pp_size"] = args.pp
        if args.force:
            payload["force"] = True

    # Inject parsed stats so server can skip S3 download
    if not is_s3:
        payload["num_lines"] = stats["num_lines"]
        payload["avg_input_tokens"] = stats["avg_input_tokens"]
        payload["max_input_tokens"] = stats["max_input_tokens"]

    # Always chunk — single code path for all jobs
    step(f"Chunking {stats['num_lines'] if not is_s3 else '?'} requests into {chunk_size}-line chunks for {effective_replicas} replica(s)...")
    chunk_infos = split_and_upload_chunks(input_file, chunk_size)
    step(f"Uploaded {c(str(len(chunk_infos)), GREEN+BOLD)} chunks to S3")

    payload["chunks"] = chunk_infos
    payload["replicas"] = effective_replicas

    # ── Phase 3: Solve placement (Koi + roofline in parallel) ─────────
    print()
    use_koi = KOI_SERVICE_URL and not args.gpu and not is_s3
    koi_data = None

    if use_koi:
        import threading as _thr
        step("Running Koi + Orca roofline in parallel...")

        koi_job = {
            "model_name": model_name,
            "task_type": "batch",
