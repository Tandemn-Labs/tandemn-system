def cmd_swap(args):
    """Hot-swap replicas to a new GPU/TP/PP config mid-job."""
    print(LOGO)
    header("SWAP REPLICAS")
    job_id = args.job_id

    # Verify job exists
    # Check job (may not be in tracker after server restart, but chunks in Redis)
    resp = api("get", f"/job/{job_id}", timeout=10)
    if resp.status_code == 200:
        job = resp.json()
        print(f"\n  Job: {c(job_id, BOLD)}")
        print(f"  Status: {job.get('status', '?')}")
    else:
        # Job not in tracker — check Redis for chunks
        progress_resp = api("get", f"/job/{job_id}/chunks/progress", timeout=10)
        if progress_resp.status_code != 200:
            print(f"\n  {RED}Job {job_id} not found{RESET}\n")
            sys.exit(1)
        progress = progress_resp.json()
        print(f"\n  Job: {c(job_id, BOLD)} {DIM}(recovered from Redis){RESET}")
        print(f"  Chunks: {progress['completed']}/{progress['total']} completed, {progress['inflight']} inflight")

    # Show current replicas
    rep_resp = api("get", f"/job/{job_id}/replicas", timeout=10)
    if rep_resp.status_code == 200:
        replicas = rep_resp.json().get("replicas", [])
        print(f"\n  Current replicas ({len(replicas)}):")
        for r in replicas:
            rid = r.get("replica_id", "?")
            phase = r.get("phase", "?")
            color = GREEN if phase == "running" else YELLOW if phase == "launching" else RED
            print(f"    {rid}: {c(phase, color)}")

    # Build swap payload
    payload = {
        "gpu_type": args.gpu,
        "tp_size": args.tp or 1,
        "pp_size": args.pp or 1,
        "on_demand": args.on_demand,
        "force": args.force,
        "ready_threshold": args.ready_threshold,
    }
    if args.replicas is not None:
        payload["num_replicas"] = args.replicas

    print(f"\n  Swapping to: {c(args.gpu, BOLD)} TP={payload['tp_size']} PP={payload['pp_size']}")

    resp = api("post", f"/job/{job_id}/swap", json=payload, timeout=30)
    if resp.status_code != 200:
        data = resp.json() if resp.headers.get("content-type", "").startswith("application/json") else {}
        if data.get("status") == "confirm":
            print(f"\n  {YELLOW}Warning:{RESET} {data.get('message', 'Config may not be feasible')}")
            print(f"  Use {BOLD}--force{RESET} to proceed anyway.\n")
            sys.exit(1)
        print(f"\n  {RED}Error:{RESET} {resp.text}\n")
        sys.exit(1)

    data = resp.json()
    print(f"\n  {GREEN}Swap initiated!{RESET}")
    print(f"  Old replicas: {', '.join(data.get('old_replicas', []))}")
    print(f"  New replicas: {', '.join(data.get('new_replicas', []))}")
    print(f"  Ready threshold: {data.get('ready_threshold', '?')}")
    print(f"  Version: v{data.get('version', '?')}")
    print(f"\n  {DIM}New replicas will start pulling chunks from the same queue.")
    print(f"  Old replicas will be killed after {data.get('ready_threshold', 1)} new replica(s) start inferring.{RESET}\n")


