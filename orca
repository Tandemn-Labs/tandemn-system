def _call_advisor(payload):
    """Call /test/placement with placement_solver=llm. Returns placements list or None."""
    adv_payload = {k: v for k, v in payload.items()
                   if k not in ("chunks", "replicas", "force", "persist",
                                "prefer_spot", "s3_model_path", "hf_token")}
    adv_payload["placement_solver"] = "llm"
    adv_payload["input_file"] = adv_payload.get("input_file", "s3://plan-dry-run/placeholder")
    try:
        resp = api("post", "/test/placement", json=adv_payload)
        if resp.status_code in (200, 201):
            data = resp.json()
            if data.get("status") != "error":
                return data.get("placements") or []
    except Exception as e:
        print(f"{YELLOW}Warning:{RESET} Advisor error: {e}", file=sys.stderr)
    return None


