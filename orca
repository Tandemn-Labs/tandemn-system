def cmd_ls(args):
    """List all jobs in a clean table, most recent first."""
    from concurrent.futures import ThreadPoolExecutor, as_completed

    STATUS_COLORS = {
        "succeeded": GREEN,
        "failed": RED,
        "generating": CYAN,
        "loading_model": BLUE,
        "model_ready": BLUE,
        "launching": YELLOW,
        "queued": YELLOW,
        "running": CYAN,
        "cancelled": DIM,
    }
    STATUS_ICONS = {
        "succeeded": f"{GREEN}\u2713{RESET}",
        "failed": f"{RED}\u2717{RESET}",
        "cancelled": f"{DIM}\u2717{RESET}",
    }
    STATUS_LABELS = {
        "loading_model": "loading model",
        "model_ready": "model ready",
    }
    INACTIVE = {"succeeded", "failed", "cancelled"}

    resp = api("get", "/jobs", timeout=15)
    if resp.status_code != 200:
        print(f"{RED}Error:{RESET} {resp.text}")
        return

    jobs = resp.json()
    if isinstance(jobs, dict):
        jobs = jobs.get("jobs", [])

    if not jobs:
        print(f"{DIM}No jobs found.{RESET}")
        return

    # Sort by created_at descending
    jobs.sort(key=lambda j: j.get("created_at", 0), reverse=True)

    # --- JSON mode ---
    if getattr(args, "json", False):
        print(json.dumps(jobs, indent=2, default=str))
        return

    # --- Enrichment ---
    verbose = getattr(args, "verbose", False)

    def enrich(job):
        jid = job.get("job_id") or job.get("id", "")
        info = {"replicas": [], "chunks": {}, "metrics": {}, "detail": {}}
        for label, path, key in [
            ("details", f"/job/{jid}", "detail"),
            ("replicas", f"/job/{jid}/replicas", "replicas"),
            ("chunks", f"/job/{jid}/chunks/progress", "chunks"),
        ]:
            try:
                r = api("get", path, timeout=8)
                if r.status_code == 200:
                    data = r.json()
                    if key == "replicas":
                        data = data if isinstance(data, list) else data.get("replicas", [])
                    info[key] = data
            except Exception as e:
                print(f"  {DIM}Could not enrich {label} for {jid}: {e}{RESET}", file=sys.stderr)
        if verbose:
            try:
                r = api("get", f"/job/{jid}/metrics", timeout=8)
                if r.status_code == 200:
                    info["metrics"] = r.json()
            except Exception as e:
                print(f"  {DIM}Could not enrich metrics for {jid}: {e}{RESET}", file=sys.stderr)
        return jid, info

    enrich_all = getattr(args, "all", False)
    enrichment: dict = {}

    jobs_to_enrich = jobs if enrich_all else [j for j in jobs if j.get("status") not in INACTIVE]
    if jobs_to_enrich:
        with ThreadPoolExecutor(max_workers=min(8, len(jobs_to_enrich))) as pool:
            futs = {pool.submit(enrich, j): j for j in jobs_to_enrich}
            for fut in as_completed(futs):
                try:
                    jid, info = fut.result()
                    enrichment[jid] = info
                except Exception as e:
                    print(f"  {DIM}Enrichment failed: {e}{RESET}", file=sys.stderr)

    # --- Helpers ---
    def _status_display(status):
        icon = STATUS_ICONS.get(status, f"{STATUS_COLORS.get(status, DIM)}\u25cf{RESET}")
        label = STATUS_LABELS.get(status, status)
        return f"{icon} {c(label, STATUS_COLORS.get(status, DIM))}"

    def _progress_str(job, info):
        num_lines = job.get("num_lines", 0) or 0
        chunks = info.get("chunks", {})
        # Use chunk-level completed count if available (more accurate for chunked jobs)
        done_reqs = 0
        if chunks.get("completed", 0) and chunks.get("total", 0):
            # Estimate completed prompts from chunk ratio
            chunk_ratio = chunks["completed"] / chunks["total"]
            done_reqs = int(num_lines * chunk_ratio)
        elif job.get("progress") is not None:
            done_reqs = int(num_lines * float(job["progress"]))
        elif job.get("status") == "succeeded":
            done_reqs = num_lines
        if num_lines:
            return f"{done_reqs:,d}/{num_lines:,d}"
        return f"{DIM}\u2014{RESET}"

    def _instance_str(job, info):
        replicas = info.get("replicas", [])
        detail = info.get("detail", {})
        instance = ""
        if replicas:
            instance = replicas[0].get("instance_type", "")
        if not instance:
            instance = detail.get("instance_type", "")
        if not instance:
            return f"{DIM}\u2014{RESET}", ""
        num_replicas = len(replicas) if replicas else 1
        inst_str = instance
        if num_replicas > 1:
            inst_str += f" {DIM}(\u00d7{num_replicas}){RESET}"
        return inst_str, instance

    def _region_str(info):
        replicas = info.get("replicas", [])
        if replicas:
            region = replicas[0].get("region") or ""
            if region:
                return f"aws {region}"
        return ""

    # --- Render table ---
    print()
    hdr = (
        f"  {BOLD}{DIM}{'MODEL':<34s} {'STATUS':<20s} {'PROGRESS':<16s} "
        f"{'INSTANCE':<24s} {'REGION':<16s}{RESET}"
    )
    print(hdr)
    print(f"  {DIM}{'─' * 110}{RESET}")

    for job in jobs:
        jid = job.get("job_id") or job.get("id", "")
        model = job.get("model_name", "?")
        status = job.get("status", "unknown")
        info = enrichment.get(jid, {})

        # Truncate model name if too long
        model_display = model if len(model) <= 32 else model[:29] + "..."

        status_display = _status_display(status)
        progress = _progress_str(job, info)
        inst_display, _ = _instance_str(job, info)
        region = _region_str(info)

        # Build row — use visible_len-aware padding for colored fields
        model_pad = 34 - visible_len(model_display)
        status_pad = 20 - visible_len(status_display)
        progress_pad = 16 - visible_len(progress)
        inst_pad = 24 - visible_len(inst_display)

        row = (
            f"  {model_display}{' ' * max(0, model_pad)}"
            f" {status_display}{' ' * max(0, status_pad)}"
            f" {progress}{' ' * max(0, progress_pad)}"
            f" {inst_display}{' ' * max(0, inst_pad)}"
            f" {region}"
        )
        print(row)

        # --- Verbose: detail lines under each active job ---
        if verbose and (status not in INACTIVE or enrich_all):
            detail_parts = []

            # Endpoint
            endpoint = info.get("detail", {}).get("endpoint_url", "")
            if endpoint:
                detail_parts.append(f"endpoint: {endpoint}")

            # Chunks
            chunks = info.get("chunks", {})
            total_chunks = chunks.get("total", 0)
            if total_chunks:
                chunk_parts = [f"{chunks.get('completed', 0)}/{total_chunks} chunks"]
                inflight = chunks.get("inflight", 0)
                if inflight:
                    chunk_parts.append(f"{c(str(inflight), CYAN)} in-flight")
                failed = chunks.get("failed", 0)
                if failed:
                    chunk_parts.append(f"{c(str(failed), RED)} failed")
                detail_parts.append("  ".join(chunk_parts))

            # Metrics
            metrics = info.get("metrics", {})
            tps = metrics.get("avg_generation_throughput_toks_per_s")
            kv = metrics.get("gpu_cache_usage_perc")
            running = metrics.get("num_requests_running")
            if any(v is not None for v in [tps, kv, running]):
                m_parts = []
                if tps is not None:
                    m_parts.append(f"{c(f'{tps:,.0f}', GREEN)} tok/s")
                if kv is not None:
                    kv_pct = kv * 100 if kv <= 1 else kv
                    m_parts.append(f"KV {kv_pct:.0f}%")
                if running is not None:
                    m_parts.append(f"{int(running)} running")
                detail_parts.append("  ".join(m_parts))

            if detail_parts:
                print(f"  {DIM}{'':34s} {' \u00b7 '.join(detail_parts)}{RESET}")

            # Replicas
            replicas = info.get("replicas", [])
            if replicas and len(replicas) > 1:
                PHASE_COLORS = {"running": GREEN, "generating": GREEN, "launching": YELLOW,
                                "provisioned": CYAN, "completed": GREEN, "failed": RED,
                                "dead": RED, "swapped_out": DIM}
                for rep in replicas:
                    rid = rep.get("replica_id", "?")
                    short_r = rid.rsplit("-", 1)[-1] if "-r" in rid else rid[-8:]
                    phase = rep.get("phase", "?")
                    phase_color = PHASE_COLORS.get(phase, DIM)
                    r_region = rep.get("region") or ""
                    market = rep.get("market") or ""
                    inst = rep.get("instance_type") or ""
                    print(
                        f"  {'':34s} {DIM}{short_r}{RESET}  "
                        f"{c(phase, phase_color):<18s}  {r_region}  {market}  {inst}"
                    )

        # blank line between jobs only in verbose mode
        if verbose:
            print()

    print()
    print(f"  {DIM}{len(jobs)} job(s){RESET}")
    print()


def cmd_web(args):
    """Open the Orca web dashboard in browser."""
    import webbrowser
    port = getattr(args, 'port', None)
    if port:
        url = f"http://localhost:{port}/dashboard"
    else:
        url = f"{ORCA_SERVER}/dashboard"
    print(LOGO)
    header("WEB DASHBOARD")
    step(f"Dashboard URL: {c(url, CYAN+BOLD)}")
    step(f"Opening in browser...")
    print()
    try:
        webbrowser.open(url)
    except Exception:
        step(f"Could not open browser. Open manually: {url}")
    step(f"{DIM}Dashboard connects to server via SSE for live updates.{RESET}")
    step(f"{DIM}Press Ctrl+C to close.{RESET}")
    print()


# ─── Main ────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="orca",
        description="Orca - Batch Inference Orchestrator by Tandemn",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Environment:
  ORCA_SERVER   Control plane URL (default: http://localhost:26336)
  HF_TOKEN      HuggingFace token for gated models

Examples:
  orca plan Qwen/Qwen3-32B demo_batch.jsonl
  orca deploy Qwen/Qwen3-32B demo_batch.jsonl --slo 4
  orca progress
  orca status
        """,
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # deploy
    p_deploy = subparsers.add_parser("deploy", help="Deploy a model for batch inference")
    p_deploy.add_argument("model_name", help="Model name (e.g., Qwen/Qwen3-32B)")
    p_deploy.add_argument("input_file", help="Path to JSONL batch file (local or s3://)")
    p_deploy.add_argument("--slo", type=_hours, default=4, help="SLO deadline in hours, e.g. 4, 0.5h, 30m (default: 4)")
    p_deploy.add_argument("--max-output-tokens", type=int, default=1024, help="Max output tokens per request")
    p_deploy.add_argument("--output", "-o", help="Output file name (default: output.jsonl)")
    p_deploy.add_argument("--gpu", help="GPU type (e.g., L40S, A100, H100). Triggers user_specified solver.")
    p_deploy.add_argument("--tp", type=int, help="Tensor parallelism (1,2,4,8)")
    p_deploy.add_argument("--pp", type=int, help="Pipeline parallelism (1,2,3,4)")
    p_deploy.add_argument("--force", action="store_true", help="Skip feasibility check, launch anyway")
    p_deploy.add_argument("--persist", action="store_true", help="Keep cluster alive after job completes (default: destroy)")
    p_deploy.add_argument("--on-demand", action="store_true", help="Use on-demand instances instead of spot")
    p_deploy.add_argument("--replicas", type=int, default=None, help="Number of replica clusters (auto if omitted)")
    p_deploy.add_argument("--chunk-size", type=int, default=None, help="Lines per chunk for multi-replica (default: 1000)")
    p_deploy.add_argument("--s3-models", type=str, default=None, metavar="S3_URI",
                          help="S3 path to model weights (e.g. s3://tandemn-model-shards/hf-models/Qwen/Qwen3-32B)")
    p_deploy.add_argument("--log-level", default="info", choices=["debug", "info", "warning"])
    p_deploy.add_argument("--quantization", choices=["fp16", "fp8", "int8"], default=None,
                          help="Quantization (default: fp16, no quantization)")
    p_deploy.add_argument("--no-advisor", action="store_true",
                          help="Skip LLM advisor, use roofline solver only")
    p_deploy.add_argument("--skip-dangerously", action="store_true",
                          help="Auto-pick Koi recommendation without prompting")

    # plan
    p_plan = subparsers.add_parser("plan", help="Run solver and show placement plan (no launch)")
    p_plan.add_argument("model_name", help="Model name (e.g., Qwen/Qwen3-32B)")
    p_plan.add_argument("input_file", help="Path to JSONL batch file (local or s3://)")
    p_plan.add_argument("--slo", type=_hours, default=4, help="SLO deadline in hours, e.g. 4, 0.5h, 30m (default: 4)")
    p_plan.add_argument("--max-output-tokens", type=int, default=1024, help="Max output tokens per request")
    p_plan.add_argument("--verbose", "-v", action="store_true", help="Show full solver log")
    p_plan.add_argument("--gpu", help="GPU type (e.g., L40S, A100, H100). Triggers user_specified solver.")
    p_plan.add_argument("--tp", type=int, help="Tensor parallelism (1,2,4,8)")
    p_plan.add_argument("--pp", type=int, help="Pipeline parallelism (1,2,3,4)")
    p_plan.add_argument("--quantization", choices=["fp16", "fp8", "int8"], default=None,
                        help="Quantization (default: fp16, no quantization)")
    p_plan.add_argument("--no-advisor", action="store_true",
                        help="Skip LLM advisor, use roofline solver only")
    p_plan.add_argument("--log-level", default="info", choices=["debug", "info", "warning"])

    # progress
    p_progress = subparsers.add_parser("progress", help="Monitor job progress")
    p_progress.add_argument("job_id", nargs="?", help="Job ID to monitor (optional)")

    # status
    p_status = subparsers.add_parser("status", help="Show status of all jobs")
    p_status.add_argument("-v", "--verbose", action="store_true", help="Rich view with replicas, chunks, GPU util")
    p_status.add_argument("--all", action="store_true", help="Enrich completed/failed jobs too (verbose mode)")
    p_status.add_argument("--json", action="store_true", help="Output raw JSON")

    # logs
    p_logs = subparsers.add_parser("logs", help="Stream logs from a job cluster")
    p_logs.add_argument("cluster_id", nargs="?", help="Cluster name / job ID")

    # clusters
    subparsers.add_parser("clusters", help="Show active SkyPilot clusters")

    # metrics
    p_metrics = subparsers.add_parser("metrics", help="Show live vLLM metrics for a job")
    p_metrics.add_argument("job_id", help="Job ID to inspect")
    p_metrics.add_argument("--watch", "-w", action="store_true", help="Refresh every 2s")
    p_metrics.add_argument("--replica", "-r", help="Show metrics for a specific replica (e.g. mo-xxx-r0)")
    p_metrics.add_argument("--compare", "-c", action="store_true", help="Show aggregated + per-replica side by side")

    # history
    p_history = subparsers.add_parser("history", help="Show completed run history")
    p_history.add_argument("--model", help="Filter by model name (substring match)")
    p_history.add_argument("--gpu", help="Filter by GPU type (exact match, e.g. L40S)")
    p_history.add_argument("--limit", type=int, default=50, help="Max rows (default: 50)")

    # inspect
    p_inspect = subparsers.add_parser("inspect", help="Show full details for a completed run (all 117 fields)")
    p_inspect.add_argument("run_id", help="Run ID (number) or job ID (mo-...)")
    p_inspect.add_argument("--replicas", action="store_true", help="Show all per-replica summaries side by side")
    p_inspect.add_argument("--replica", help="Show full metrics for a specific replica")

    # timeseries
    p_ts = subparsers.add_parser("timeseries", help="Show scheduler timeseries for a completed run")
    p_ts.add_argument("run_id", help="Run ID (number) or job ID (mo-...)")

    # stream
    p_stream = subparsers.add_parser("stream", help="Stream live SSE metrics for a running job")
    p_stream.add_argument("job_id", help="Job ID to stream")

    # add
    p_add = subparsers.add_parser("add", help="Add replicas to a running job")
    p_add.add_argument("job_id", help="Job ID to add replicas to")
    p_add.add_argument("count", type=int, help="Number of replicas to add")
    p_add.add_argument("--gpu", help="GPU type (default: inherit from job)")
    p_add.add_argument("--tp", type=int, help="Tensor parallelism (default: inherit)")
    p_add.add_argument("--pp", type=int, help="Pipeline parallelism (default: inherit)")
    p_add.add_argument("--on-demand", action="store_true", help="Use on-demand instances")
    p_add.add_argument("--force", action="store_true", help="Skip feasibility check")

    # kill
    p_kill = subparsers.add_parser("kill", help="Kill specific replicas of a job")
    p_kill.add_argument("job_id", help="Job ID")
    p_kill.add_argument("--replica", action="append", required=True, help="Replica ID to kill (repeatable)")

    # swap
    p_swap = subparsers.add_parser("swap", help="Hot-swap replicas to new GPU config mid-job")
    p_swap.add_argument("job_id", help="Job ID to swap replicas for")
    p_swap.add_argument("--gpu", required=True, help="New GPU type (e.g., A100, H100, L40S)")
    p_swap.add_argument("--tp", type=int, default=1, help="Tensor parallelism (default: 1)")
    p_swap.add_argument("--pp", type=int, default=1, help="Pipeline parallelism (default: 1)")
    p_swap.add_argument("--replicas", type=int, default=None, help="New replica count (default: same as current)")
    p_swap.add_argument("--ready-threshold", type=int, default=1, help="Wait for K new replicas before killing old")
    p_swap.add_argument("--on-demand", action="store_true", help="Use on-demand instances")
    p_swap.add_argument("--force", action="store_true", help="Skip feasibility check")

    # destroy
    p_destroy = subparsers.add_parser("destroy", help="Tear down Orca clusters")
    p_destroy.add_argument("job_id", nargs="?", help="Job ID to destroy clusters for")
    p_destroy.add_argument("--all", action="store_true", help="Destroy ALL Orca clusters")

    # web
    p_web = subparsers.add_parser("web", help="Open real-time web dashboard")
    p_web.add_argument("--port", type=int, help="Override server port")

    # ls
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        print(LOGO)
        sys.exit(0)

    commands = {
        "deploy": cmd_deploy,
        "plan": cmd_plan,
        "progress": cmd_progress,
        "status": cmd_status,
        "logs": cmd_logs,
        "clusters": cmd_clusters,
        "metrics": cmd_metrics,
        "history": cmd_history,
        "inspect": cmd_inspect,
        "timeseries": cmd_timeseries,
        "stream": cmd_stream,
        "destroy": cmd_destroy,
        "add": cmd_add,
        "kill": cmd_kill,
        "swap": cmd_swap,
        "web": cmd_web,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
