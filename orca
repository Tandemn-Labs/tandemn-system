def _poll_replica_launch(job_id, num_replicas):
    """Poll /job/{id}/replicas until all settled or job completes, whichever comes first."""
    ORCA_FISH = "><(((o>~~~"
    PHASE_ICON = {
        "launching": f"{YELLOW}..{RESET}",
        "provisioned": f"{GREEN}ok{RESET}",
        "running": f"{GREEN}ok{RESET}",
        "completed": f"{GREEN}ok{RESET}",
        "failed": f"{RED}!!{RESET}",
    }
    print(f"\n  {CYAN}{ORCA_FISH}{RESET} launching {num_replicas} replicas...\n")
    seen = {}  # replica_id → last printed phase
    deadline = time.time() + 900  # 15 min max wait
    try:
        while time.time() < deadline:
            try:
                resp = api("get", f"/job/{job_id}/replicas", timeout=5)
                if resp.status_code != 200:
                    time.sleep(5)
                    continue
                replicas = resp.json().get("replicas", [])
            except Exception:
                time.sleep(5)
                continue

            for r in replicas:
                rid = r["replica_id"]
                phase = r.get("phase", "launching")
                if rid in seen and seen[rid] == phase:
                    continue
                seen[rid] = phase
                icon = PHASE_ICON.get(phase, f"{DIM}?{RESET}")
                # Short replica label: r0, r1 from "mo-xxx-r0"
                short = rid.rsplit("-", 1)[-1] if "-r" in rid else rid[-6:]
                region = r.get("region") or ""
                market = r.get("market") or ""
                loc = f"({region}, {market})" if region else ""
                print(f"  [{icon}] {short}  {DIM}{rid}{RESET}  {loc}")

            # Exit when all replicas are past "launching"
            if len(seen) >= num_replicas and all(
                p in ("provisioned", "running", "completed", "failed")
                for p in seen.values()
            ):
                break

            # Exit early if job already finished (fewer replicas did all the work)
            try:
                jr = api("get", f"/job/{job_id}", timeout=3)
                if jr.status_code == 200:
                    status = jr.json().get("status")
                    if status in ("succeeded", "failed"):
                        print(f"\n  {DIM}Job already {status} — stop waiting for remaining replicas.{RESET}")
                        break
            except Exception:
                pass

            time.sleep(5)
        else:
            print(f"\n  {DIM}Timed out waiting. Replicas continue launching in background.{RESET}")
    except KeyboardInterrupt:
        print(f"\n  {DIM}Replicas continue launching in background.{RESET}")


# ─── Commands ────────────────────────────────────────────────────────────────
def cmd_deploy(args):
    """Deploy a model for batch inference."""
    print(LOGO)
    header("DEPLOY")

    model_name = args.model_name
    input_file = args.input_file
    is_s3 = input_file.startswith("s3://")

    if not is_s3 and not os.path.exists(input_file):
        print(f"\n  {RED}Error:{RESET} Input file not found: {input_file}")
        sys.exit(1)

    # ── Phase 1: Parse input ─────────────────────────────────────────────
    if is_s3:
        step("Using S3 input (stats parsed by server)...")
    else:
        step("Parsing input file...")
        stats = parse_input_file(input_file)
        print()
        lines = [
            f"{DIM}File:{RESET}       {c(input_file, WHITE+BOLD)}",
            f"{DIM}Model:{RESET}      {c(model_name, WHITE+BOLD)}",
            f"{DIM}Prompts:{RESET}    {c(str(stats['num_lines']), GREEN+BOLD)}",
            f"{DIM}Avg input:{RESET}  {stats['avg_input_tokens']} tokens",
            f"{DIM}Max input:{RESET}  {stats['max_input_tokens']} tokens",
            f"{DIM}Max output:{RESET} {args.max_output_tokens} tokens",
            f"{DIM}SLO:{RESET}        {args.slo} hours",
        ]
        print(box(lines, title="WORKLOAD"))

    # ── Phase 2: Determine replica count + chunk if needed ──────────────
    print()
    chunk_size = getattr(args, 'chunk_size', None) or 1000
    effective_replicas = getattr(args, 'replicas', None) or 0

    # Build common payload fields
    payload = {
        "placement_solver": "user_specified" if args.gpu else "roofline",
        "user_id": "orca-cli",
        "input_file": "s3://placeholder/chunked",  # overwritten below
        "output_file": args.output or "output.jsonl",
        "avg_output_tokens": args.max_output_tokens,
        "max_output_tokens": args.max_output_tokens,
        "description": f"Orca CLI deploy: {model_name}",
        "task_type": "batch",
        "task_priority": "normal",
        "model_name": model_name,
        "engine": "vllm",
        "slo_mode": "batch",
        "slo_deadline_hours": args.slo,
        "placement": "aws",
        "s3_models": False,
        "persist": args.persist,
        "prefer_spot": not args.on_demand,
        "hf_token": os.environ.get("HF_TOKEN", ""),
        "log_level": args.log_level,
    }

    if args.gpu:
        payload["gpu_type"] = args.gpu
        if args.tp:
            payload["tp_size"] = args.tp
        if args.pp:
            payload["pp_size"] = args.pp
        if args.force:
            payload["force"] = True

    # Inject parsed stats so server can skip S3 download
    if not is_s3:
        payload["num_lines"] = stats["num_lines"]
        payload["avg_input_tokens"] = stats["avg_input_tokens"]
        payload["max_input_tokens"] = stats["max_input_tokens"]

    if effective_replicas > 1:
        # Path A: --replicas N → chunk immediately
        step(f"Chunking {stats['num_lines'] if not is_s3 else '?'} requests into {chunk_size}-line chunks for {effective_replicas} replicas...")
        chunk_infos = split_and_upload_chunks(input_file, chunk_size)
        step(f"Uploaded {c(str(len(chunk_infos)), GREEN+BOLD)} chunks to S3")

        payload["chunks"] = chunk_infos
        payload["replicas"] = effective_replicas
    elif effective_replicas == 0 and not args.gpu:
        # Path B: No --replicas → ask solver for replica count first
        step("Running placement solver...")
        plan_resp = api_with_spinner("post", "/test/placement",
                                      message="Running solver...", json=payload)
        if plan_resp.status_code not in (200, 201):
            print(f"\n  {RED}Server error ({plan_resp.status_code}):{RESET} {plan_resp.text}\n")
            sys.exit(1)
        plan_data = plan_resp.json()
        if plan_data.get("status") == "error":
            print(f"\n  {RED}Solver error:{RESET} {plan_data.get('message', 'Unknown')}")
            sys.exit(1)

        placements = plan_data.get("placements", [])
        solver_replicas = placements[0].get("replicas", 1) if placements else 1

        if solver_replicas > 1 and not is_s3:
            step(f"Solver recommends {c(str(solver_replicas), CYAN+BOLD)} replicas. Chunking...")
            chunk_infos = split_and_upload_chunks(input_file, chunk_size)
            step(f"Uploaded {c(str(len(chunk_infos)), GREEN+BOLD)} chunks to S3")

            payload["chunks"] = chunk_infos
            payload["replicas"] = solver_replicas
        else:
            # Single replica — upload full file
            if is_s3:
                s3_input = input_file
                step(f"Using S3 path: {c(s3_input, DIM)}")
            else:
                step("Uploading input file to storage...")
                s3_input = upload_to_server(input_file)
                step(f"Uploaded to {c(s3_input, DIM)}")
            payload["input_file"] = s3_input
    else:
        # Single replica (explicit --replicas 1 or --gpu) — upload full file
        if is_s3:
            s3_input = input_file
            step(f"Using S3 path: {c(s3_input, DIM)}")
        else:
            step("Uploading input file to storage...")
            s3_input = upload_to_server(input_file)
            step(f"Uploaded to {c(s3_input, DIM)}")
        payload["input_file"] = s3_input

    # ── Phase 3: Submit ──────────────────────────────────────────────────
    print()
    if args.gpu:
        step(f"Running feasibility check: {c(args.gpu, CYAN)} TP={args.tp or 1} PP={args.pp or 1}...")
    elif not payload.get("chunks"):
        step("Submitting job...")

    resp = api_with_spinner("post", "/submit/batch",
                            message="Solving placement + launching cluster...", json=payload)
    if resp.status_code not in (200, 201):
        print(f"\n  {RED}Server error ({resp.status_code}):{RESET} {resp.text}\n")
        sys.exit(1)
    data = resp.json()

    if data.get("status") == "confirm":
        cfg = data.get("config", {})
        warn_lines = [
            f"{YELLOW}Solver Warning:{RESET} {data['message']}",
            f"",
            f"{DIM}Instance:{RESET}  {cfg.get('instance_type', '?')}",
            f"{DIM}Config:{RESET}    TP={cfg.get('tp', '?')} PP={cfg.get('pp', '?')}",
        ]
        if data.get("quota_warning"):
            warn_lines.append(f"")
            warn_lines.append(f"{YELLOW}Quota:{RESET}    {data['quota_warning']}")
        print()
        print(box(warn_lines, title="FEASIBILITY CHECK"))

        answer = input(f"\n  {YELLOW}Proceed anyway? [y/N]:{RESET} ").strip().lower()
        if answer != "y":
            print(f"\n  {DIM}Aborted.{RESET}")
            sys.exit(0)

        # Re-submit with force
        payload["force"] = True
        resp = api("post", "/submit/batch", json=payload)
        data = resp.json()

    if data.get("status") == "launched":
        job_id = data["job_id"]
        cfg = data.get("config", {})
        solver_info = data.get("feasibility") or data.get("solver_info") or {}
        sol = solver_info.get("solution") or {}
        num_chunks = data.get("chunks", 0)
        num_replicas = data.get("replicas", 0)
        success_lines = [
            f"{GREEN}{BOLD}Job launched successfully!{RESET}",
            f"",
            f"{DIM}Job ID:{RESET}    {c(job_id, CYAN+BOLD)}",
            f"{DIM}Instance:{RESET}  {cfg.get('instance_type', '?')}",
            f"{DIM}Config:{RESET}    TP={cfg.get('tp_size', '?')} PP={cfg.get('pp_size', '?')}",
        ]
        if num_chunks:
            success_lines.append(f"{DIM}Chunks:{RESET}    {num_chunks}")
        if num_replicas:
            success_lines.append(f"{DIM}Replicas:{RESET}  {num_replicas}")
        if sol.get("throughput_tokens_per_sec"):
            success_lines.append(f"{DIM}Est. tps:{RESET}  {sol['throughput_tokens_per_sec']:.0f} tok/s")
        if solver_info.get("max_model_len"):
            success_lines.append(f"{DIM}Max ctx:{RESET}   {solver_info['max_model_len']}")
        if data.get("quota_warning"):
            success_lines.append(f"")
            success_lines.append(f"{YELLOW}Quota:{RESET}    {data['quota_warning']}")
        success_lines.append(f"")
        success_lines.append(f"Track progress: {c('orca progress ' + job_id, WHITE+BOLD)}")
        print()
        print(box(success_lines, title="SUCCESS"))

        # Poll replica launch progress for chunked jobs
        if num_replicas and num_replicas > 1:
            _poll_replica_launch(job_id, num_replicas)
    else:
        print(f"\n  {RED}Launch failed:{RESET} {data.get('message', 'Unknown error')}")
        if data.get("detail"):
            print(f"  {DIM}{json.dumps(data['detail'], indent=2)}{RESET}")
        sys.exit(1)

    print()


def cmd_plan(args):
    """Run solver only, show the plan without launching."""
    print(LOGO)
    header("PLAN")

    model_name = args.model_name
    input_file = args.input_file

    is_s3 = input_file.startswith("s3://")
    if not is_s3 and not os.path.exists(input_file):
        print(f"\n  {RED}Error:{RESET} Input file not found: {input_file}")
        sys.exit(1)

    if is_s3:
        step("Using S3 input (stats parsed by server)...")
    else:
        step("Parsing input file...")
        stats = parse_input_file(input_file)
        print()
        lines = [
            f"{DIM}File:{RESET}       {c(input_file, WHITE+BOLD)}",
            f"{DIM}Model:{RESET}      {c(model_name, WHITE+BOLD)}",
            f"{DIM}Prompts:{RESET}    {c(str(stats['num_lines']), GREEN+BOLD)}",
            f"{DIM}Avg input:{RESET}  {stats['avg_input_tokens']} tokens",
            f"{DIM}Max input:{RESET}  {stats['max_input_tokens']} tokens",
            f"{DIM}Max output:{RESET} {args.max_output_tokens} tokens",
            f"{DIM}SLO:{RESET}        {args.slo} hours",
        ]
        print(box(lines, title="WORKLOAD"))

    print()
    step("Running Orca placement solver...")
    t0 = time.time()

    # For plan, send locally-parsed stats directly — no S3 upload needed
    # (the file only needs to be in S3 for deploy, where the EC2 node fetches it)
    payload = {
        "placement_solver": "user_specified" if args.gpu else "roofline",
        "user_id": "orca-cli",
        "input_file": input_file if input_file.startswith("s3://") else "s3://plan-dry-run/placeholder",
        "output_file": "output.jsonl",
        "avg_output_tokens": args.max_output_tokens,
        "max_output_tokens": args.max_output_tokens,
        "description": f"Orca CLI plan: {model_name}",
        "task_type": "batch",
        "task_priority": "normal",
        "model_name": model_name,
        "engine": "vllm",
        "slo_mode": "batch",
        "slo_deadline_hours": args.slo,
        "placement": "aws",
        "log_level": args.log_level,
    }
    # Inject locally-parsed stats so server skips the S3 download
    if not is_s3:
        payload["num_lines"] = stats["num_lines"]
        payload["avg_input_tokens"] = stats["avg_input_tokens"]
        payload["max_input_tokens"] = stats["max_input_tokens"]

    if args.gpu:
        payload["gpu_type"] = args.gpu
        if args.tp:
            payload["tp_size"] = args.tp
        if args.pp:
            payload["pp_size"] = args.pp

    resp = api("post", "/test/placement", json=payload)
    elapsed = time.time() - t0

    if resp.status_code not in (200, 201):
        print(f"\n  {RED}Server error ({resp.status_code}):{RESET} {resp.text}\n")
        sys.exit(1)
    data = resp.json()
    if data.get("status") == "error":
        print(f"\n  {RED}Solver error:{RESET} {data.get('message', 'Unknown')}")
        sys.exit(1)

    step(f"Solver completed in {c(f'{elapsed:.2f}s', GREEN)}")

    configs = data.get("placements") or data.get("configs") or []
    if not configs:
        print(f"\n  {RED}No feasible configuration found.{RESET}")
        sys.exit(1)

    # User-specified GPU: show feasibility check box
    if args.gpu:
        cfg = configs[0]
        is_feasible = cfg.get("feasible", True)
        print()
        if is_feasible:
            lines = [
                f"{DIM}Status:{RESET}       {c('FEASIBLE', GREEN+BOLD)}",
