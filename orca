def cmd_destroy(args):
    """Tear down Orca clusters, Redis state, and S3 uploads."""
    import subprocess as _sp
    print(LOGO)
    header("DESTROY")

    if not args.all and not args.job_id:
        print(f"\n  {DIM}Specify --all or a job_id.{RESET}\n")
        return

    # ── 1. Discover SkyPilot clusters ────────────────────────────────────
    step("Finding Orca clusters...")
    try:
        import sky as _sky
        _rid = _sky.status()
        _all_clusters = _sky.stream_and_get(_rid)
    except Exception as e:
        print(f"  {YELLOW}Warning:{RESET} Could not query SkyPilot: {e}")
        _all_clusters = []

    if args.all:
        orca_clusters = [c.name for c in _all_clusters if c.name.startswith("mo-")]
    else:
        orca_clusters = [c.name for c in _all_clusters if c.name.startswith(args.job_id)]

    # ── 2. Discover Redis chunk keys ─────────────────────────────────────
    redis_keys = []
    redis_jobs = set()
    try:
        import redis as _redis
        r = _redis.from_url(os.environ.get("REDIS_URL", "redis://localhost:6379/0"), decode_responses=True)
        r.ping()
        all_chunk_keys = r.keys("chunk:job:*")
        if args.all:
            redis_keys = all_chunk_keys
        else:
            redis_keys = [k for k in all_chunk_keys if args.job_id in k]
        # Extract unique job IDs
        for k in redis_keys:
            parts = k.split(":")
            if len(parts) >= 3:
                redis_jobs.add(parts[2])
    except Exception as e:
        print(f"  {YELLOW}Warning:{RESET} Redis unreachable ({e}). Chunk/S3 cleanup skipped.")

    # ── 3. Discover S3 paths from Redis chunk metadata ─────────────────
    s3_files = []  # individual S3 URIs to delete
    try:
        if redis_jobs and r:
            for jid in sorted(redis_jobs):
                order_key = f"chunk:job:{jid}:output_order"
                chunk_ids = r.lrange(order_key, 0, -1)
                for cid in chunk_ids:
                    info = r.hgetall(f"chunk:job:{jid}:chunk:{cid}")
                    inp = info.get("s3_input_path", "")
                    out = info.get("s3_output_path", "")
                    if inp:
                        s3_files.append(inp)
                    if out:
                        s3_files.append(out)
                # Also the assembled output.jsonl
                meta = r.hgetall(f"chunk:job:{jid}:meta")
                out_base = meta.get("s3_output_base", "")
                if out_base:
                    s3_files.append(f"{out_base}/output.jsonl")
    except Exception:
        pass

    # ── 4. Show summary and confirm ──────────────────────────────────────
    total_items = len(orca_clusters) + (1 if redis_keys else 0) + len(s3_files)
    if total_items == 0:
        target = "Orca" if args.all else args.job_id
        print(f"\n  {DIM}Nothing to clean up for {target}.{RESET}\n")
        return

    print()
    if orca_clusters:
        print(f"  {BOLD}Clusters ({len(orca_clusters)}):{RESET}")
        for name in orca_clusters:
            print(f"    {DIM}-{RESET} {name}")
    if redis_keys:
        print(f"  {BOLD}Redis keys ({len(redis_keys)}):{RESET}  jobs: {', '.join(sorted(redis_jobs))}")
    if s3_files:
        print(f"  {BOLD}S3 files ({len(s3_files)}):{RESET}  inputs + outputs for {', '.join(sorted(redis_jobs))}")
    print()

    answer = input(f"  {YELLOW}Destroy all of the above? [y/N]:{RESET} ").strip().lower()
    if answer != "y":
        print(f"\n  {DIM}Aborted.{RESET}\n")
        return

    # ── 5. Execute ───────────────────────────────────────────────────────
    print()

    # Clusters
    for name in orca_clusters:
        step(f"Destroying cluster {c(name, CYAN)}...")
        try:
            _rid = _sky.down(name)
            _sky.stream_and_get(_rid)
        except Exception as e:
            print(f"  {YELLOW}Warning:{RESET} Failed to destroy {name}: {e}")
    if orca_clusters:
        step(f"Destroyed {len(orca_clusters)} cluster(s)", icon=f"{GREEN}✔{RESET}")

    # S3 — delete files via server's storage API
    if s3_files:
        step(f"Cleaning {len(s3_files)} S3 file(s) via server...")
        deleted = 0
        failed = 0
        for path in s3_files:
            try:
                resp = api("delete", "/storage/delete_s3", params={"path": path, "user": "system"}, timeout=10)
                if resp.status_code == 200:
                    deleted += 1
                else:
                    failed += 1
            except Exception:
                failed += 1
        msg = f"Deleted {deleted} S3 file(s)"
        if failed:
            msg += f"  {DIM}({failed} missing/already deleted){RESET}"
        step(msg, icon=f"{GREEN}✔{RESET}")

    # Redis — delete last (contains the S3 paths we just used)
    if redis_keys:
        step(f"Cleaning {len(redis_keys)} Redis keys...")
        try:
            pipe = r.pipeline()
            for k in redis_keys:
                pipe.delete(k)
            pipe.execute()
            step(f"Cleaned {len(redis_keys)} Redis keys ({len(redis_jobs)} job(s))", icon=f"{GREEN}✔{RESET}")
        except Exception as e:
            print(f"  {RED}Redis cleanup failed:{RESET} {e}")

    print()


def _render_snap(md, label):
    """Render a single metrics snapshot into display lines."""
    tps = md.get("avg_generation_throughput_toks_per_s", 0)
    kv = md.get("gpu_cache_usage_perc", 0) * 100
    running = md.get("num_requests_running", 0)
    waiting = md.get("num_requests_waiting", 0)
    done = int(md.get("request_success_total", 0))
    ttft = md.get("ttft_ms_p50")
    tpot = md.get("tpot_ms_p50")
    lines = [
        f"{DIM}Throughput:{RESET}   {c(f'{tps:.0f}', GREEN+BOLD)} tok/s",
        f"{DIM}KV Cache:{RESET}     {bar(kv / 100, 30)}",
        f"{DIM}Running:{RESET}      {c(str(running), CYAN)}   {DIM}Waiting:{RESET} {waiting}",
        f"{DIM}Completed:{RESET}    {done}",
    ]
    if ttft is not None:
        lines.append(f"{DIM}TTFT p50:{RESET}     {ttft:.1f}ms")
    if tpot is not None:
        lines.append(f"{DIM}TPOT p50:{RESET}     {tpot:.1f}ms")
    return box(lines, title=label)


def cmd_metrics(args):
    """Show live vLLM metrics for a job."""
    job_id = args.job_id
    watch = args.watch
    replica = getattr(args, 'replica', None)
    compare = getattr(args, 'compare', False)

    if compare:
        print(LOGO)
        header("METRICS COMPARISON")

        def _fetch_compare():
            # Aggregated
            agg_resp = api("get", f"/job/{job_id}/metrics", timeout=5)
            if agg_resp.status_code != 200:
                return f"  {RED}No aggregated metrics for {job_id}.{RESET}"
            # Replica list
            rep_resp = api("get", f"/job/{job_id}/replicas", timeout=5)
            replicas = rep_resp.json().get("replicas", []) if rep_resp.status_code == 200 else []

            output = _render_snap(agg_resp.json(), "AGGREGATED (fleet total)")
            for r in replicas:
                rid = r["replica_id"]
                rr = api("get", f"/job/{job_id}/replicas/{rid}/metrics", timeout=5)
                if rr.status_code == 200:
                    output += "\n" + _render_snap(rr.json(), f"REPLICA: {rid}")
                else:
                    output += f"\n  {DIM}{rid}: no metrics yet{RESET}"
            return output

        if watch:
            step(f"Comparing replicas for: {c(job_id, CYAN+BOLD)} (Ctrl+C to stop)")
            print()
            prev_lines = 0
            try:
                while True:
                    rendered = _fetch_compare()
                    if prev_lines:
                        sys.stdout.write(f"\033[{prev_lines}A\033[J")
                    print(rendered)
                    sys.stdout.flush()
                    prev_lines = rendered.count("\n") + 1
                    time.sleep(2)
            except KeyboardInterrupt:
                print(f"\n\n  {DIM}Stopped.{RESET}")
        else:
            print(_fetch_compare())
        print()
        return

    def _fetch_and_render():
        if replica:
            resp = api("get", f"/job/{job_id}/replicas/{replica}/metrics", timeout=5)
        else:
            resp = api("get", f"/job/{job_id}/metrics", timeout=5)
        if resp.status_code == 404:
            return None, f"  {RED}No metrics available for {job_id}.{RESET}"
        if resp.status_code != 200:
            return None, f"  {RED}Error:{RESET} {resp.text}"
        md = resp.json()
        tps = md.get("avg_generation_throughput_toks_per_s", 0)
        kv = md.get("gpu_cache_usage_perc", 0) * 100
        running = md.get("num_requests_running", 0)
        waiting = md.get("num_requests_waiting", 0)
        swapped = md.get("num_requests_swapped", 0)
        done = int(md.get("request_success_total", 0))
        lines = [
            f"{DIM}Throughput:{RESET}   {c(f'{tps:.0f}', GREEN+BOLD)} tok/s  {DIM}(instant){RESET}",
        ]
        # Fetch sustained throughput
        try:
            sr = api("get", f"/job/{job_id}/throughput?window=60", timeout=5)
            if sr.status_code == 200:
                sd = sr.json()
                sus = sd.get("generation_toks_per_s", 0)
                lines.append(f"{DIM}Sustained:{RESET}    {c(f'{sus:.0f}', GREEN+BOLD)} tok/s  {DIM}(60s avg){RESET}")
                qp50 = sd.get("queue_time_ms_p50")
                qp95 = sd.get("queue_time_ms_p95")
                if qp50 is not None and qp95 is not None:
                    lines.append(f"{DIM}Queue:{RESET}        p50 {qp50:.0f}ms  p95 {qp95:.0f}ms")
        except Exception:
            pass
        lines += [
            f"{DIM}KV Cache:{RESET}     {bar(kv / 100, 30)}",
            f"{DIM}Running:{RESET}      {c(str(running), CYAN)}   {DIM}Waiting:{RESET} {waiting}",
            f"{DIM}Completed:{RESET}    {done}",
        ]
        return box(lines, title="METRICS"), None

    if watch:
        print(LOGO)
        header("LIVE METRICS")
        step(f"Watching job: {c(job_id, CYAN+BOLD)} (Ctrl+C to stop)")
        print()
        first = True
        try:
            while True:
                rendered, err = _fetch_and_render()
                if err:
                    if first:
                        print(err)
                        print()
                    time.sleep(2)
                    first = False
                    continue
                N = rendered.count("\n") + 1
                if not first:
                    sys.stdout.write(f"\033[{N}A")
                print(rendered)
                sys.stdout.flush()
                first = False
                time.sleep(2)
        except KeyboardInterrupt:
            print(f"\n\n  {DIM}Stopped.{RESET}")
    else:
        print(LOGO)
        header("JOB METRICS")
        rendered, err = _fetch_and_render()
        if err:
            print(err)
        else:
            print(rendered)
    print()


