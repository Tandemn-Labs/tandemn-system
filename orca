def cmd_progress(args):
    """Poll job progress."""
    print(LOGO)
    header("PROGRESS MONITOR")

    job_id = args.job_id

    # If no job_id, list recent jobs from server
    if not job_id:
        resp = api("get", "/jobs", timeout=10)
        if resp.status_code == 200:
            jobs = resp.json().get("jobs", [])
            if jobs:
                step(f"Found {len(jobs)} job(s) on server:")
                print()
                for j in jobs:
                    status = j["status"]
                    sc = GREEN if status == "succeeded" else (RED if status == "failed" else YELLOW)
                    ts = datetime.fromtimestamp(j["created_at"]).strftime("%Y-%m-%d %H:%M")
                    print(f"    {c(status, sc+BOLD):<22} {DIM}{ts}{RESET}  {j['model_name']}  [{j['job_id'][:40]}...]")
                print()
                print(f"  {DIM}Run with job ID to monitor a specific job:{RESET}")
                print(f"  {WHITE}orca progress <job_id>{RESET}\n")
            else:
                print(f"\n  {DIM}No jobs found on server.{RESET}\n")
        return

    # Poll a specific job
    step(f"Monitoring job: {c(job_id, CYAN+BOLD)}")
    print()

    resp = api("get", f"/job/{job_id}", timeout=10)
    if resp.status_code == 404:
        print(f"  {RED}Job not found:{RESET} {job_id}\n")
        return
    if resp.status_code != 200:
        print(f"  {RED}Error:{RESET} {resp.text}\n")
        return

    data = resp.json()
    status = data.get("status", "unknown")
    progress = data.get("progress", 0)

    status_colors = {"succeeded": GREEN, "failed": RED, "generating": CYAN}
    status_color = status_colors.get(status, YELLOW)
    lines = [
        f"{DIM}Job ID:{RESET}     {c(job_id, CYAN+BOLD)}",
        f"{DIM}Model:{RESET}      {data.get('model_name', '?')}",
        f"{DIM}Status:{RESET}     {c(status, status_color+BOLD)}",
        f"{DIM}Prompts:{RESET}    {data.get('num_lines', '?')}",
    ]
    if data.get("endpoint_url"):
        lines.append(f"{DIM}Endpoint:{RESET}   {data['endpoint_url']}")
    if data.get("head_ip"):
        lines.append(f"{DIM}Head IP:{RESET}    {data['head_ip']}")
    print(box(lines, title="JOB STATUS"))

    # Live poll if still running
    if status in ("running", "launching", "queued", "loading_model", "generating"):
        print()
        step("Live polling (Ctrl+C to stop)...")
        print()
        try:
            while True:
                time.sleep(2)
                resp = api("get", f"/job/{job_id}", timeout=10)
                if resp.status_code != 200:
                    break
                data = resp.json()
                progress = data.get("progress", 0)
                status = data.get("status", "unknown")
                total = data.get("num_lines", "?")

                # Live metrics from vLLM Prometheus (polled by control plane)
                running = 0
                done_reqs = 0
                metrics_line = ""
                try:
                    md = api("get", f"/job/{job_id}/metrics", timeout=2).json()
                    tps = md.get("avg_generation_throughput_toks_per_s", 0)
                    kv = md.get("gpu_cache_usage_perc", 0) * 100
                    running = md.get("num_requests_running", 0)
                    waiting = md.get("num_requests_waiting", 0)
                    done_reqs = int(md.get("request_success_total", 0))
                    parts = []
                    if done_reqs > 0:
                        parts.append(f"{GREEN}{done_reqs}{RESET}/{total} done")
                    if running > 0:
                        parts.append(f"{CYAN}{running}{RESET} running")
                    if waiting > 0:
                        parts.append(f"{YELLOW}{waiting}{RESET} waiting")
                    if kv > 0:
                        parts.append(f"KV {kv:.0f}%")
                    if tps > 0:
                        parts.append(f"{tps:.0f} tok/s")
                    if parts:
                        metrics_line = "  ".join(parts)
                except Exception:
                    pass

                # Try to get chunk-level progress for chunked jobs
                chunk_line = ""
                try:
                    cr = api("get", f"/job/{job_id}/chunks/progress", timeout=2)
                    if cr.status_code == 200:
                        cp = cr.json()
                        cp_total = cp.get("total", 0)
                        cp_done = cp.get("completed", 0)
                        cp_inflight = cp.get("inflight", 0)
                        if cp_total > 0:
                            chunk_line = f"{GREEN}{cp_done}{RESET}/{cp_total} chunks  {CYAN}{cp_inflight}{RESET} in-flight"
                except Exception:
                    pass

                if status in ("succeeded", "failed"):
                    done_count = int(progress * total) if isinstance(total, int) else total
                    sys.stdout.write(f"\r  {bar(progress, 50)}  {done_count}/{total}  [{status}]")
                    extra = f"  {chunk_line}" if chunk_line else ""
                    sys.stdout.write(f"\n  {DIM}{metrics_line}{extra}{RESET}  " if metrics_line or chunk_line else "")
                    sys.stdout.flush()
                    break

                if running > 0 or status == "generating":
                    done_frac = done_reqs / total if isinstance(total, int) and total > 0 else 0
                    chunk_info = f"  {chunk_line}" if chunk_line else ""
                    sys.stdout.write(f"\r  {bar(done_frac, 50)}  {done_reqs}/{total} done  {running} in-flight{chunk_info}  [{c(status, GREEN)}]  ")
                    sys.stdout.write(f"\n  {DIM}{metrics_line}{RESET}  \033[1A")
                else:
                    # Show current phase
                    phase_labels = {
                        "launching": "provisioning cluster...",
                        "running": "setting up environment...",
                        "loading_model": "downloading & loading model...",
                        "model_ready": "model loaded, preparing batch...",
                    }
                    phase = phase_labels.get(status, f"{status}...")
                    sys.stdout.write(f"\r  {DIM}{'░' * 50}  {phase}  [{c(status, YELLOW)}]{RESET}  ")
                sys.stdout.flush()
        except KeyboardInterrupt:
            print(f"\n\n  {DIM}Stopped polling.{RESET}")

    print()


