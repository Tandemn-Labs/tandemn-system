        ("SCHEDULER", ["running_avg", "running_max", "waiting_avg", "waiting_max",
                       "kv_cache_util_pct_avg", "kv_cache_util_pct_max", "scheduler_samples",
                       "num_preemptions", "prefix_cache_hit_rate"]),
        ("WORKLOAD", ["num_requests_total", "num_requests_completed", "total_tokens",
                      "total_input_tokens", "total_output_tokens",
                      "avg_input_tokens", "max_input_tokens", "avg_output_tokens", "max_output_tokens"]),
        ("COST", ["price_per_hour", "cost_for_run_usd", "tokens_per_dollar",
                  "cost_per_1m_tokens_total", "cost_per_1m_tokens_prefill_usd", "cost_per_1m_tokens_decode_usd"]),
