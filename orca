def _hours(value):
    """Accept '4', '0.5', '0.1h', '2h', '30m', '90m' as hours."""
    s = str(value).strip()
    if s.lower().endswith("m"):
        return float(s[:-1]) / 60
    return float(s.rstrip("hH"))

