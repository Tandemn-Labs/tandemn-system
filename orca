        return
    if resp.status_code != 200:
        print(f"\n  {RED}Error:{RESET} {resp.text}\n")
        return

    run = resp.json().get("run", {})

    groups = [
        ("IDENTITY", ["id", "job_id", "model_name", "model_architecture", "params_billion",
                       "instance_type", "gpu_name", "gpu_model", "actual_region", "actual_market", "solver"]),
        ("PARALLELISM", ["tp_size", "pp_size", "num_nodes", "gpus_per_node", "gpu_count_total"]),
        ("TIMING", ["total_runtime_sec", "model_load_time_sec", "generation_time_sec"]),
        ("THROUGHPUT", ["total_tokens_per_sec", "tokens_per_sec_per_gpu", "input_tokens_per_sec",
                        "output_tokens_per_sec", "throughput_requests_per_sec"]),
        ("LATENCY (client)", ["ttft_ms_p50", "ttft_ms_p95", "ttft_ms_p99",
                              "tpot_ms_p50", "tpot_ms_p95", "tpot_ms_p99",
                              "tpot_client_ms_p50", "tpot_client_ms_p95", "tpot_client_ms_p99",
                              "e2e_ms_p50", "e2e_ms_p95", "e2e_ms_p99"]),
        ("LATENCY (server)", ["ttft_server_ms_p50", "ttft_server_ms_p95", "ttft_server_ms_p99",
                              "e2e_server_ms_p50", "e2e_server_ms_p95", "e2e_server_ms_p99"]),
        ("LATENCY (per-phase v0.10+)", ["queue_time_ms_p50", "queue_time_ms_p95", "queue_time_ms_p99",
                                        "prefill_time_ms_p50", "prefill_time_ms_p95", "prefill_time_ms_p99",
                                        "decode_time_ms_p50", "decode_time_ms_p95", "decode_time_ms_p99",
                                        "inference_time_ms_p50", "inference_time_ms_p95", "inference_time_ms_p99",
                                        "prefix_cache_hit_rate"]),
        ("GPU UTILIZATION", ["avg_sm_util_pct", "max_sm_util_pct", "avg_mem_bw_util_pct",
                             "max_mem_bw_util_pct", "avg_mem_util_pct", "max_mem_util_pct", "gpu_samples"]),
        ("SCHEDULER", ["running_avg", "running_max", "waiting_avg", "waiting_max",
                       "kv_cache_util_pct_avg", "kv_cache_util_pct_max", "scheduler_samples",
                       "num_preemptions", "prefix_cache_hit_rate"]),
        ("WORKLOAD", ["num_requests_total", "num_requests_completed", "total_tokens",
                      "total_input_tokens", "total_output_tokens",
                      "avg_input_tokens", "max_input_tokens", "avg_output_tokens", "max_output_tokens"]),
        ("COST", ["price_per_hour", "cost_for_run_usd", "tokens_per_dollar",
                  "cost_per_1m_tokens_total", "cost_per_1m_tokens_prefill_usd", "cost_per_1m_tokens_decode_usd"]),
        ("MODEL", ["vocab_size", "is_moe", "num_experts_active", "model_size_gb",
                   "model_fits_single_gpu", "vram_headroom_gb", "attention_heads_per_kv_head", "kv_heads_per_tp"]),
        ("HARDWARE", ["gpu_mem_gb", "gpu_bandwidth_gbps", "gpu_tflops_fp16", "gpu_generation",
                      "interconnect", "bandwidth_per_param", "flops_per_param", "crosses_node_boundary"]),
        ("ENGINE", ["max_model_len", "max_num_seqs", "gpu_memory_utilization", "dtype",
                    "kv_cache_dtype", "precision", "runtime_stack"]),
    ]

    print()
    populated = 0
    total_fields = 0
    for group_name, fields in groups:
        lines = []
        for f in fields:
            v = run.get(f)
            total_fields += 1
            if v is None:
                lines.append(f"{DIM}{f}:{RESET} {DIM}—{RESET}")
            else:
                populated += 1
                if isinstance(v, float):
                    if "per_sec" in f or "per_dollar" in f or "per_hour" in f:
                        # Rate fields — no unit suffix
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v:.1f}', WHITE)}")
                    elif "pct" in f:
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v:.1f}%', GREEN)}")
                    elif f == "gpu_memory_utilization":
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v * 100:.0f}%', GREEN)}")
                    elif "util" in f and v <= 1.0:
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v * 100:.1f}%', GREEN)}")
                    elif "_ms_" in f:
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v:.1f}ms', CYAN)}")
                    elif "_sec" in f or f.endswith("_sec"):
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v:.1f}s', WHITE)}")
                    elif "usd" in f or "cost" in f or "price" in f:
                        lines.append(f"{DIM}{f}:{RESET} {c(f'${v:.4f}', YELLOW)}")
                    else:
                        lines.append(f"{DIM}{f}:{RESET} {c(f'{v:.2f}', WHITE)}")
                else:
                    lines.append(f"{DIM}{f}:{RESET} {c(str(v), WHITE)}")
        print(box(lines, title=group_name))
        print()

    print(f"  {BOLD}{populated}/{total_fields} fields populated{RESET}\n")


def cmd_timeseries(args):
    """Show scheduler timeseries for a completed run."""
    print(LOGO)
    header("TIMESERIES")

    run_id = args.run_id

    # Resolve job_id to run_id
    if run_id.startswith("mo-"):
        resp = api("get", "/analytics/runs", params={"limit": 200}, timeout=30)
        runs = resp.json().get("runs", []) if resp.status_code == 200 else []
        match = [r for r in runs if r.get("job_id") == run_id]
        if not match:
            print(f"\n  {RED}Run not found for job_id:{RESET} {run_id}\n")
            return
        run_id = str(match[0]["id"])

    resp = api("get", f"/analytics/runs/{run_id}/timeseries", timeout=15)
    if resp.status_code != 200:
        print(f"\n  {RED}Error:{RESET} {resp.text}\n")
        return

    data = resp.json()
    ts_list = data.get("timeseries", [])
    job_id = data.get("job_id", "?")

    if not ts_list:
        print(f"\n  {DIM}No timeseries data for run {run_id}.{RESET}\n")
        return

    print()
    step(f"Job: {c(job_id, CYAN+BOLD)}  ({len(ts_list)} samples)")
    print()

    # Table header
    hdr = f"  {'TIME':>8}  {'RUNNING':>7}  {'WAITING':>7}  {'KV %':>6}  {'TOK/S':>7}"
    print(f"  {hdr}")
    print(f"  {'─'*8}  {'─'*7}  {'─'*7}  {'─'*6}  {'─'*7}")

    first_ts = ts_list[0].get("timestamp", 0)
    for row in ts_list:
        t = row.get("timestamp", 0) - first_ts
        running = row.get("num_requests_running", 0)
        waiting = row.get("num_requests_waiting", 0)
        kv = row.get("gpu_cache_usage_perc", 0)
        if isinstance(kv, (int, float)):
            kv_pct = kv * 100 if kv <= 1.0 else kv
        else:
            kv_pct = 0
        tps = row.get("avg_generation_throughput_toks_per_s", 0)

        # Color running count
        if running > 0:
            run_str = c(f"{running:>7}", GREEN)
        else:
            run_str = f"{running:>7}"

        print(f"  {t:>7.0f}s  {run_str}  {waiting:>7}  {kv_pct:>5.0f}%  {tps:>7.0f}")

    print()


def cmd_stream(args):
    """Stream live SSE metrics for a running job."""
    print(LOGO)
    header("LIVE STREAM")

    job_id = args.job_id
    step(f"Streaming metrics for: {c(job_id, CYAN+BOLD)} (Ctrl+C to stop)")
    print()

    print(f"  {'TIME':>8}  {'GEN TOK/S':>9}  {'SUSTAINED':>9}  {'PROMPT TOK/S':>12}  {'RUN':>5}  {'WAIT':>5}  {'KV %':>6}  {'QUEUE':>7}  {'SUCCESS':>7}  {'PREEMPT':>7}")
    print(f"  {'─'*8}  {'─'*9}  {'─'*9}  {'─'*12}  {'─'*5}  {'─'*5}  {'─'*6}  {'─'*7}  {'─'*7}  {'─'*7}")

    import requests as _req
    url = f"{ORCA_SERVER}/job/{job_id}/metrics/stream"
    try:
        with _req.get(url, stream=True, timeout=600) as resp:
            if resp.status_code != 200:
                print(f"\n  {RED}Error:{RESET} {resp.status_code} {resp.text[:200]}\n")
                return
            start = time.time()
            for line in resp.iter_lines(decode_unicode=True):
                if not line or not line.startswith("data:"):
                    continue
                data_str = line[5:].strip()
                if not data_str or data_str == "":
                    continue
                try:
                    d = json.loads(data_str)
                except (json.JSONDecodeError, ValueError):
                    continue

                if d.get("status") == "completed":
                    print(f"\n  {GREEN}Job completed.{RESET}\n")
                    return

                t = time.time() - start
                tps = d.get("avg_generation_throughput_toks_per_s", 0)
                ptps = d.get("avg_prompt_throughput_toks_per_s", 0)
                run = d.get("num_requests_running", 0)
                wait = d.get("num_requests_waiting", 0)
                kv = d.get("gpu_cache_usage_perc", 0) * 100
                succ = d.get("request_success_total", 0)
                pre = d.get("num_preemptions_total", 0)

                sus = d.get("sustained", {})
                sus_tps = sus.get("generation_toks_per_s", 0)
                sus_str = f"{sus_tps:>9.0f}" if sus else f"{'—':>9}"

                qp95 = d.get("queue_time_ms_p95")
                q_str = f"{qp95:>6.0f}ms" if qp95 is not None else f"{'—':>7}"

                run_str = c(f"{run:>5}", GREEN) if run > 0 else f"{run:>5}"
                print(f"  {t:>7.0f}s  {tps:>9.0f}  {sus_str}  {ptps:>12.0f}  {run_str}  {wait:>5}  {kv:>5.0f}%  {q_str}  {succ:>7.0f}  {pre:>7.0f}")

    except KeyboardInterrupt:
        print(f"\n\n  {DIM}Stopped.{RESET}")
    except Exception as e:
        print(f"\n  {RED}Connection error:{RESET} {e}\n")
    print()


def cmd_history(args):
    """Show completed run history from the analytics DB."""
    print(LOGO)
    header("RUN HISTORY")

    params: dict = {"limit": args.limit}
    if args.model:
        params["model"] = args.model
    if args.gpu:
        params["gpu"] = args.gpu

    resp = api("get", "/analytics/runs", params=params, timeout=10)
    if resp.status_code != 200:
        print(f"\n  {RED}Error:{RESET} {resp.text}\n")
        return

    data = resp.json()
    runs = data.get("runs", [])

    if not runs:
        print(f"\n  {DIM}No completed runs found.{RESET}\n")
        return

    print()
    print(f"  {'ID':<5} {'JOB ID':<35} {'MODEL':<30} {'GPU':<8} {'TOK/S':>7} {'RT(s)':>7}  {'CREATED'}")
    print(f"  {'─'*5} {'─'*35} {'─'*30} {'─'*8} {'─'*7} {'─'*7}  {'─'*18}")

    for r in runs:
        run_id = r.get("id", "?")
        job_id_short = (r.get("job_id") or "")[:32] + "..."
        model = (r.get("model_name") or "?")[:30]
        gpu = (r.get("gpu_name") or "?")[:8]
        tps = r.get("total_tokens_per_sec")
        tps_str = f"{tps:.0f}" if tps else "?"
        rt = r.get("total_runtime_sec")
        rt_str = f"{rt:.0f}" if rt else "?"
        created = ""
        if r.get("created_at"):
            created = datetime.fromtimestamp(r["created_at"]).strftime("%Y-%m-%d %H:%M")
        print(f"  {run_id:<5} {job_id_short:<35} {model:<30} {gpu:<8} {tps_str:>7} {rt_str:>7}  {created}")

    print()


# ─── Main ────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="orca",
        description="Orca - Batch Inference Orchestrator by Tandemn",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Environment:
  ORCA_SERVER   Control plane URL (default: http://localhost:26336)
  HF_TOKEN      HuggingFace token for gated models

Examples:
  orca plan Qwen/Qwen3-32B demo_batch.jsonl
  orca deploy Qwen/Qwen3-32B demo_batch.jsonl --slo 4
  orca progress
  orca status
        """,
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # deploy
    p_deploy = subparsers.add_parser("deploy", help="Deploy a model for batch inference")
    p_deploy.add_argument("model_name", help="Model name (e.g., Qwen/Qwen3-32B)")
    p_deploy.add_argument("input_file", help="Path to JSONL batch file (local or s3://)")
    p_deploy.add_argument("--slo", type=_hours, default=4, help="SLO deadline in hours, e.g. 4, 0.5h, 30m (default: 4)")
    p_deploy.add_argument("--max-output-tokens", type=int, default=1024, help="Max output tokens per request")
    p_deploy.add_argument("--output", "-o", help="Output file name (default: output.jsonl)")
    p_deploy.add_argument("--gpu", help="GPU type (e.g., L40S, A100, H100). Triggers user_specified solver.")
    p_deploy.add_argument("--tp", type=int, help="Tensor parallelism (1,2,4,8)")
    p_deploy.add_argument("--pp", type=int, help="Pipeline parallelism (1,2,3,4)")
    p_deploy.add_argument("--force", action="store_true", help="Skip feasibility check, launch anyway")
    p_deploy.add_argument("--persist", action="store_true", help="Keep cluster alive after job completes (default: destroy)")
    p_deploy.add_argument("--on-demand", action="store_true", help="Use on-demand instances instead of spot")
    p_deploy.add_argument("--replicas", type=int, default=None, help="Number of replica clusters (auto if omitted)")
    p_deploy.add_argument("--chunk-size", type=int, default=None, help="Lines per chunk for multi-replica (default: 1000)")
    p_deploy.add_argument("--log-level", default="info", choices=["debug", "info", "warning"])

    # plan
    p_plan = subparsers.add_parser("plan", help="Run solver and show placement plan (no launch)")
    p_plan.add_argument("model_name", help="Model name (e.g., Qwen/Qwen3-32B)")
    p_plan.add_argument("input_file", help="Path to JSONL batch file (local or s3://)")
    p_plan.add_argument("--slo", type=_hours, default=4, help="SLO deadline in hours, e.g. 4, 0.5h, 30m (default: 4)")
    p_plan.add_argument("--max-output-tokens", type=int, default=1024, help="Max output tokens per request")
    p_plan.add_argument("--verbose", "-v", action="store_true", help="Show full solver log")
    p_plan.add_argument("--gpu", help="GPU type (e.g., L40S, A100, H100). Triggers user_specified solver.")
    p_plan.add_argument("--tp", type=int, help="Tensor parallelism (1,2,4,8)")
    p_plan.add_argument("--pp", type=int, help="Pipeline parallelism (1,2,3,4)")
    p_plan.add_argument("--log-level", default="info", choices=["debug", "info", "warning"])

    # progress
    p_progress = subparsers.add_parser("progress", help="Monitor job progress")
    p_progress.add_argument("job_id", nargs="?", help="Job ID to monitor (optional)")

    # status
    subparsers.add_parser("status", help="Show status of all jobs")

    # logs
    p_logs = subparsers.add_parser("logs", help="Stream logs from a job cluster")
    p_logs.add_argument("cluster_id", nargs="?", help="Cluster name / job ID")

    # clusters
    subparsers.add_parser("clusters", help="Show active SkyPilot clusters")

    # metrics
    p_metrics = subparsers.add_parser("metrics", help="Show live vLLM metrics for a job")
    p_metrics.add_argument("job_id", help="Job ID to inspect")
    p_metrics.add_argument("--watch", "-w", action="store_true", help="Refresh every 2s")
    p_metrics.add_argument("--replica", "-r", help="Show metrics for a specific replica (e.g. mo-xxx-r0)")
    p_metrics.add_argument("--compare", "-c", action="store_true", help="Show aggregated + per-replica side by side")

    # history
    p_history = subparsers.add_parser("history", help="Show completed run history")
    p_history.add_argument("--model", help="Filter by model name (substring match)")
    p_history.add_argument("--gpu", help="Filter by GPU type (exact match, e.g. L40S)")
    p_history.add_argument("--limit", type=int, default=50, help="Max rows (default: 50)")

    # inspect
    p_inspect = subparsers.add_parser("inspect", help="Show full details for a completed run (all 117 fields)")
    p_inspect.add_argument("run_id", help="Run ID (number) or job ID (mo-...)")

    # timeseries
    p_ts = subparsers.add_parser("timeseries", help="Show scheduler timeseries for a completed run")
    p_ts.add_argument("run_id", help="Run ID (number) or job ID (mo-...)")

    # stream
    p_stream = subparsers.add_parser("stream", help="Stream live SSE metrics for a running job")
    p_stream.add_argument("job_id", help="Job ID to stream")

    # destroy
    p_destroy = subparsers.add_parser("destroy", help="Tear down Orca clusters")
    p_destroy.add_argument("job_id", nargs="?", help="Job ID to destroy clusters for")
    p_destroy.add_argument("--all", action="store_true", help="Destroy ALL Orca clusters")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        print(LOGO)
        sys.exit(0)

    commands = {
        "deploy": cmd_deploy,
        "plan": cmd_plan,
        "progress": cmd_progress,
        "status": cmd_status,
        "logs": cmd_logs,
        "clusters": cmd_clusters,
        "metrics": cmd_metrics,
        "history": cmd_history,
        "inspect": cmd_inspect,
        "timeseries": cmd_timeseries,
        "stream": cmd_stream,
        "destroy": cmd_destroy,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
