#!/usr/bin/env python3
"""
Orca CLI - Batch Inference Orchestrator

Thin HTTP client that talks to the Orca control plane server.
Set ORCA_SERVER env var to point to your control plane (default: http://localhost:26336).

Usage:
    orca deploy <model_name> <input_file> [options]
    orca plan <model_name> <input_file> [options]
    orca progress [job_id]
    orca status
    orca logs <cluster_id>
    orca clusters

Examples:
    orca deploy Qwen/Qwen3-32B demo_batch.jsonl
    orca deploy Qwen/Qwen2.5-72B-Instruct demo_batch.jsonl --slo 4
    orca plan Qwen/Qwen3-32B demo_batch.jsonl
    orca progress
    orca status
"""
import argparse
import json
import os
import re
import sys
import time
from datetime import datetime
from pathlib import Path

try:
    import requests as http
except ImportError:
    print("Error: 'requests' package is required. Install with: pip install requests")
    sys.exit(1)

# ─── Config ──────────────────────────────────────────────────────────────────
ORCA_SERVER = os.environ.get("ORCA_SERVER", "http://localhost:26336")

# ─── ANSI helpers ────────────────────────────────────────────────────────────
BOLD    = "\033[1m"
DIM     = "\033[2m"
RESET   = "\033[0m"
RED     = "\033[31m"
GREEN   = "\033[32m"
YELLOW  = "\033[33m"
BLUE    = "\033[34m"
MAGENTA = "\033[35m"
CYAN    = "\033[36m"
WHITE   = "\033[37m"

def c(text, color):
    return f"{color}{text}{RESET}"

def bar(pct, width=40):
    filled = int(width * pct)
    empty = width - filled
    if pct >= 1.0:
        color = GREEN
    elif pct >= 0.5:
        color = CYAN
    else:
        color = BLUE
    return f"{color}{'█' * filled}{'░' * empty}{RESET} {pct*100:5.1f}%"

def visible_len(text):
    return len(re.sub(r'\033\[[0-9;]*m', '', text))

def box(lines, title="", width=72):
    top = f"╭─{'─ ' + c(title, BOLD+CYAN) + ' ─' if title else '─'}" + "─" * (width - len(title) - 6 if title else width - 2) + "╮"
    bottom = f"╰{'─' * (width)}╯"
    result = [top]
    for line in lines:
        padding = max(0, width - visible_len(line))
        result.append(f"│ {line}{' ' * padding}│")
    result.append(bottom)
    return "\n".join(result)


