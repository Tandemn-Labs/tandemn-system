            success_lines.append(f"{YELLOW}Quota:{RESET}    {data['quota_warning']}")
        success_lines.append(f"")
        success_lines.append(f"Track progress: {c('orca progress ' + job_id, WHITE+BOLD)}")
        print()
        print(box(success_lines, title="SUCCESS"))

