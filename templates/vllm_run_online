set -euxo pipefail
source .venv/bin/activate

# Manual Ray cluster setup (bypasses broken SkyPilot start_cluster script)
RAY_PORT=6379

if [ "$SKYPILOT_NODE_RANK" == "0" ]; then
    echo "Starting Ray head node..."
    ray start --head --port=$RAY_PORT --dashboard-host=0.0.0.0 --disable-usage-stats
else
    echo "Starting Ray worker node, connecting to head..."
    HEAD_IP=$(echo "$SKYPILOT_NODE_IPS" | head -n1)
    for i in {{1..60}}; do
        if ray start --address="$HEAD_IP:$RAY_PORT" --disable-usage-stats 2>/dev/null; then
            echo "Connected to Ray head at $HEAD_IP:$RAY_PORT"
            break
        fi
        echo "Waiting for Ray head... attempt $i/60"
        sleep 2
    done
fi

ray status

if [ "$SKYPILOT_NODE_RANK" == "0" ]; then
    echo "Starting vLLM server..."
    setsid nohup vllm serve {model} \
    --host {host} \
    --port {port} \
    -tp {tp} \
    -pp {pp} \
    --hf-token "$HF_TOKEN" \
    {additional_params} > vllm.log 2>&1 &
    
    VLLM_PID=$!
    disown $VLLM_PID

    tail -f vllm.log &
    TAIL_PID=$!

    URL="http://localhost:8001/v1/models"
    MAX_TRIES=600
    INTERVAL=3

    echo "LOADING MODEL... (This may take a few minutes)"
    echo "Streaming vLLM logs:"
    echo "---"
    
    for ((i=1; i<=$MAX_TRIES; i++)); do
        if curl -sf "$URL" > /dev/null 2>&1; then
            echo "---"
            echo "✓ vLLM API server is up!"
            kill $TAIL_PID 2>/dev/null || true
            exit 0
        fi
        sleep "$INTERVAL"
    done

    kill $TAIL_PID 2>/dev/null || true
fi
